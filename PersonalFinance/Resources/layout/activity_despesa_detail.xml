<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/finance_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <TextView style="@style/FinanceScreenTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Detalhes da despesa" />
        <TextView style="@style/FinanceScreenSubtitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:layout_marginBottom="20dp" android:text="Informações completas deste compromisso." />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_card" android:elevation="1dp" android:orientation="vertical" android:padding="18dp">
            <TextView style="@style/FinanceDetailLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="DESCRIÇÃO" />
            <TextView android:id="@+id/tvDescricao" style="@style/FinanceDetailValue" android:layout_width="match_parent" android:layout_height="wrap_content" />
            <TextView style="@style/FinanceDetailLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CATEGORIA" />
            <TextView android:id="@+id/tvCategoria" style="@style/FinanceDetailValue" android:layout_width="match_parent" android:layout_height="wrap_content" />
            <TextView style="@style/FinanceDetailLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="VALOR" />
            <TextView android:id="@+id/tvValor" style="@style/FinanceDetailValue" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/finance_danger" android:textStyle="bold" />
            <TextView style="@style/FinanceDetailLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="DATA DE CADASTRO" />
            <TextView android:id="@+id/tvDataCadastro" style="@style/FinanceDetailValue" android:layout_width="match_parent" android:layout_height="wrap_content" />
            <TextView style="@style/FinanceDetailLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="VENCIMENTO" />
            <TextView android:id="@+id/tvVencimento" style="@style/FinanceDetailValue" android:layout_width="match_parent" android:layout_height="wrap_content" />
            <TextView style="@style/FinanceDetailLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="NÚMERO DA PARCELA" />
            <TextView android:id="@+id/tvNParcela" style="@style/FinanceDetailValue" android:layout_width="match_parent" android:layout_height="wrap_content" />
            <TextView style="@style/FinanceDetailLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="RECEITA VINCULADA" />
            <TextView android:id="@+id/tvReceitaId" style="@style/FinanceDetailValue" android:layout_width="match_parent" android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
