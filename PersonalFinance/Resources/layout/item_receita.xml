<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:elevation="1dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tvFontePagadora"
            style="@style/FinanceItemTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fonte pagadora" />

        <TextView
            android:id="@+id/tvDescricaoReceita"
            style="@style/FinanceItemMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Descrição da receita" />

        <TextView
            android:id="@+id/tvTipoReceita"
            style="@style/FinanceItemMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Tipo" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvValorReceita"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:gravity="end"
        android:text="R$ 0,00"
        android:textColor="@color/finance_success"
        android:textSize="15sp" />
</LinearLayout>
