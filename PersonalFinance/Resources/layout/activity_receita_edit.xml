<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/finance_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <TextView style="@style/FinanceScreenTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Editar receita" />
        <TextView style="@style/FinanceScreenSubtitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:layout_marginBottom="20dp" android:text="Atualize os dados desta entrada." />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_card" android:elevation="1dp" android:orientation="vertical" android:padding="18dp">
            <TextView style="@style/FinanceFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Mês de referência" />
            <EditText android:id="@+id/edtMesReferenciaEdit" style="@style/FinanceInput" android:clickable="true" android:focusable="false" android:hint="MM/AAAA" android:inputType="date" />
            <TextView style="@style/FinanceFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Fonte pagadora" />
            <EditText android:id="@+id/edtFonteEdit" style="@style/FinanceInput" android:hint="Digite a fonte" android:inputType="textCapWords" />
            <TextView style="@style/FinanceFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Descrição" />
            <EditText android:id="@+id/edtDescricaoEdit" style="@style/FinanceInput" android:hint="Descrição da receita" android:inputType="textCapSentences" />
            <TextView style="@style/FinanceFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Tipo" />
            <EditText android:id="@+id/edtTipoEdit" style="@style/FinanceInput" android:hint="Ex.: Fixa ou variável" android:inputType="textCapWords" />
            <TextView style="@style/FinanceFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Valor" />
            <EditText android:id="@+id/edtValorEdit" style="@style/FinanceInput" android:hint="0,00" android:inputType="numberDecimal" />
        </LinearLayout>

        <Button android:id="@+id/btnSalvarEdit" style="@style/FinanceButtonPrimary" android:layout_marginTop="18dp" android:text="Salvar alterações" />
        <Button android:id="@+id/btnExcluirReceita" style="@style/FinanceButtonDanger" android:layout_marginTop="10dp" android:layout_marginBottom="12dp" android:text="Excluir receita" />
    </LinearLayout>
</ScrollView>
