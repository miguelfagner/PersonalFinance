<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/finance_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <TextView style="@style/FinanceScreenTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Nova despesa" />
        <TextView style="@style/FinanceScreenSubtitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:layout_marginBottom="20dp" android:text="Planeje um compromisso e mantenha os vencimentos sob controle." />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_card" android:elevation="1dp" android:orientation="vertical" android:padding="18dp">
            <TextView style="@style/FinanceFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Receita vinculada" />
            <Spinner android:id="@+id/spinnerReceita" style="@style/FinanceSpinner" />
            <TextView style="@style/FinanceFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Categoria" />
            <Spinner android:id="@+id/spinnerCategoria" style="@style/FinanceSpinner" />
            <TextView style="@style/FinanceFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Descrição" />
            <EditText android:id="@+id/edtDescricao" style="@style/FinanceInput" android:hint="Descrição da despesa" android:inputType="textCapSentences" />
            <TextView style="@style/FinanceFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Valor" />
            <EditText android:id="@+id/edtValor" style="@style/FinanceInput" android:hint="0,00" android:inputType="numberDecimal" />
            <TextView style="@style/FinanceFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Número da parcela" />
            <EditText android:id="@+id/edtNParcela" style="@style/FinanceInput" android:hint="Ex.: 1" android:inputType="number" />
            <TextView style="@style/FinanceFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Data de vencimento" />
            <EditText android:id="@+id/edtVencimento" style="@style/FinanceInput" android:clickable="true" android:focusable="false" android:hint="dd/MM/yyyy" android:inputType="date" />
        </LinearLayout>

        <Button android:id="@+id/btnSalvar" style="@style/FinanceButtonPrimary" android:layout_marginTop="18dp" android:layout_marginBottom="12dp" android:text="Salvar despesa" />
    </LinearLayout>
</ScrollView>
