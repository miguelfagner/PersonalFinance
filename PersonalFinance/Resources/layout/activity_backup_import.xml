<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/finance_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            style="@style/FinanceScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Importar backup" />

        <TextView
            style="@style/FinanceScreenSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="20dp"
            android:text="Restaure os dados de um arquivo de backup exportado anteriormente." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="1dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                style="@style/FinanceCardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Antes de continuar" />

            <TextView
                style="@style/FinanceScreenSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="A importação substituirá todos os dados atuais. O arquivo será validado antes da restauração." />
        </LinearLayout>

        <Button
            android:id="@+id/btnImportarArquivo"
            style="@style/FinanceButtonDanger"
            android:layout_marginTop="18dp"
            android:text="Escolher backup" />
    </LinearLayout>
</ScrollView>
