<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/finance_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <TextView style="@style/FinanceScreenTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Detalhes da transação" />
        <TextView style="@style/FinanceScreenSubtitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:layout_marginBottom="20dp" android:text="Consulte os dados registrados para este pagamento." />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_card" android:elevation="1dp" android:orientation="vertical" android:padding="18dp">
            <TextView style="@style/FinanceCardTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Transação registrada" />
            <TextView style="@style/FinanceScreenSubtitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Os detalhes completos podem ser revisados pela tela de edição." />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
