<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@color/finance_background"
    android:fitsSystemWindows="true">

    <TextView
        android:id="@+id/tvMesAtual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_hero"
        android:elevation="2dp"
        android:gravity="center"
        android:padding="16dp"
        android:text="MES ATUAL"
        android:textColor="@color/finance_white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvSaldo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="SALDO APOS COMPROMISSOS: R$ 0,00"
                    android:textColor="@color/finance_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvResumo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:text="SITUACAO FINANCEIRA"
                    android:textColor="@color/finance_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTotalDespesa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TOTAL DAS DESPESAS"
                    android:textColor="@color/finance_danger"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progDespesa"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginTop="6dp"
                    android:backgroundTint="@color/finance_surface_alt"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/finance_danger" />

                <TextView
                    android:id="@+id/tvGastosPessoais"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PESSOAL"
                    android:textColor="@color/finance_warning"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progGastosPessoais"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginTop="6dp"
                    android:backgroundTint="@color/finance_surface_alt"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/finance_warning" />

                <TextView
                    android:id="@+id/tvGastosDomesticos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CASA / DOMESTICOS"
                    android:textColor="@color/finance_info"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progGastosDomesticos"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginTop="6dp"
                    android:backgroundTint="@color/finance_surface_alt"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/finance_info" />

                <TextView
                    android:id="@+id/tvCombustivel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="COMBUSTIVEL"
                    android:textColor="@color/finance_accent"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progCombustivel"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginTop="6dp"
                    android:backgroundTint="@color/finance_surface_alt"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/finance_accent" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="RESUMO FINANCEIRO"
                    android:textColor="@color/finance_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTotalReceita"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="RECEITA DO MES: R$ 0,00"
                    android:textColor="@color/finance_success"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTotalQuitado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="TOTAL REALIZADO: R$ 0,00"
                    android:textColor="@color/finance_info"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvFaltaQuitar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="PREVISTO EM ABERTO: R$ 0,00"
                    android:textColor="@color/finance_warning"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSaldoPlanejado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="SALDO PLANEJADO: R$ 0,00"
                    android:textColor="@color/finance_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSaldoRealizado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="SALDO REALIZADO: R$ 0,00"
                    android:textColor="@color/finance_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDesvioOrcamento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="DESVIO DO PLANEJADO: R$ 0,00"
                    android:textColor="@color/finance_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/finance_border" />

                <TextView
                    android:id="@+id/tvComprometimentoRenda"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="COMPROMETIMENTO DA RENDA: 0%"
                    android:textColor="@color/finance_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvContasPendentes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="CONTAS PENDENTES: 0"
                    android:textColor="@color/finance_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMediaDiaria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="MEDIA DIARIA REALIZADA: R$ 0,00"
                    android:textColor="@color/finance_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLimiteDiario"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="DISPONIVEL POR DIA: R$ 0,00"
                    android:textColor="@color/finance_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMaiorCategoria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MAIOR CONSUMO: SEM TRANSACOES"
                    android:textColor="@color/finance_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="DISTRIBUICAO DAS DESPESAS PLANEJADAS"
                    android:textColor="@color/finance_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChartDespesas"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="CONSUMO PESSOAL SEMANAL"
                    android:textColor="@color/finance_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChartSemanal"
                    android:layout_width="match_parent"
                    android:layout_height="360dp"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
