<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/finance_surface_alt"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvHeaderMesTransacao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="Transações do mês"
        android:textColor="@color/finance_primary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvHeaderTransacao"
        style="@style/FinanceItemMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="Total: R$ 0,00" />
</LinearLayout>
